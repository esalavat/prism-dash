{
  "name": "prism-dash",
  "version": "1.0.0",
  "private": true,
  "description": "PRISM DASH — a neon low-poly endless runner (web + iOS/Android via Capacitor).",
  "type": "module",
  "scripts": {
    "start": "npx serve -l 5173 .",
    "dev": "npx serve -l 5173 .",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "assets": "npx @capacitor/assets generate --iconBackgroundColor '#07071a' --iconBackgroundColorDark '#07071a'"
  },
  "keywords": ["game", "threejs", "webgl", "capacitor", "endless-runner"]
}
